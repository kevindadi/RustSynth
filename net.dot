digraph PetriNet {
  rankdir=LR;
  node [shape=circle];

  // Places
  p0 [label="ReservedByte", shape=circle, style=filled, fillcolor=lightcyan];
  p1 [label="Alphabet", shape=circle, style=filled, fillcolor=lightblue];
  p2 [label="UnprintableByte", shape=circle, style=filled, fillcolor=lightcyan];
  p3 [label="EncoderStringWriter", shape=circle, style=filled, fillcolor=lightblue];
  p4 [label="Base64Display", shape=circle, style=filled, fillcolor=lightblue];
  p5 [label="OutputSliceTooSmall", shape=circle, style=filled, fillcolor=lightcyan];
  p6 [label="InvalidByte", shape=circle, style=filled, fillcolor=lightcyan];
  p7 [label="EncoderWriter", shape=circle, style=filled, fillcolor=lightblue];
  p8 [label="DecoderReader", shape=circle, style=filled, fillcolor=lightblue];
  p9 [label="GeneralPurposeConfig", shape=circle, style=filled, fillcolor=lightblue];
  p10 [label="InvalidPadding", shape=circle, style=filled, fillcolor=lightcyan];
  p11 [label="InvalidLength", shape=circle, style=filled, fillcolor=lightcyan];
  p12 [label="InvalidLastSymbol", shape=circle, style=filled, fillcolor=lightcyan];
  p13 [label="GeneralPurpose", shape=circle, style=filled, fillcolor=lightblue];
  p14 [label="DecodeMetadata", shape=circle, style=filled, fillcolor=lightblue];
  p15 [label="InvalidLength", shape=circle, style=filled, fillcolor=lightcyan];
  p16 [label="Indifferent", shape=circle, style=filled, fillcolor=lightcyan];
  p17 [label="RequireNone", shape=circle, style=filled, fillcolor=lightcyan];
  p18 [label="DecodeError", shape=circle, style=filled, fillcolor=lightcyan];
  p19 [label="RequireCanonical", shape=circle, style=filled, fillcolor=lightcyan];
  p20 [label="DuplicatedByte", shape=circle, style=filled, fillcolor=lightcyan];
  p21 [label="OutputSliceTooSmall", shape=circle, style=filled, fillcolor=lightcyan];
  p22 [label="u8", shape=circle, style=filled, fillcolor=pink];
  p24 [label="usize", shape=circle, style=filled, fillcolor=pink];

  // Transitions
  t23 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t25 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t26 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t27 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t28 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t29 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t30 [label="holds", shape=box, style=filled, fillcolor=lightgray];
  t31 [label="holds", shape=box, style=filled, fillcolor=lightgray];

  // Flows
  p2 -> t23 [label="owner"];
  t23 -> p22 [label="member"];
  p11 -> t25 [label="owner"];
  t25 -> p24 [label="member"];
  p6 -> t26 [label="owner"];
  t26 -> p24 [label="member"];
  p6 -> t27 [label="owner"];
  t27 -> p22 [label="member"];
  p0 -> t28 [label="owner"];
  t28 -> p22 [label="member"];
  p12 -> t29 [label="owner"];
  t29 -> p24 [label="member"];
  p12 -> t30 [label="owner"];
  t30 -> p22 [label="member"];
  p20 -> t31 [label="owner"];
  t31 -> p22 [label="member"];
}
