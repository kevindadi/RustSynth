digraph ApiGraph {
  rankdir=LR;
  fontname="Helvetica";
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];

  // Type nodes (椭圆)
  subgraph cluster_types {
    label="Types";
    style=dashed;
    color=gray;
    T0 [label="i32", shape=ellipse, style=filled, fillcolor=lightgray];
    T1 [label="Range", shape=ellipse, style=filled, fillcolor=lightblue];
    T2 [label="wrap::T", shape=ellipse, style=filled, fillcolor=lightblue];
    T3 [label="Wrapper<wrap::T>", shape=ellipse, style=filled, fillcolor=lightblue];
    T4 [label="pair::A", shape=ellipse, style=filled, fillcolor=lightblue];
    T5 [label="pair::B", shape=ellipse, style=filled, fillcolor=lightblue];
    T6 [label="Pair<pair::A, pair::B>", shape=ellipse, style=filled, fillcolor=lightblue];
    T7 [label="Wrapper::T", shape=ellipse, style=filled, fillcolor=lightblue];
    T8 [label="Wrapper<Wrapper::T>", shape=ellipse, style=filled, fillcolor=lightblue];
    T9 [label="Wrapper::map::F:FnOnce", shape=ellipse, style=filled, fillcolor=lightblue];
    T10 [label="Wrapper<Wrapper::map::U>", shape=ellipse, style=filled, fillcolor=lightblue];
    T11 [label="Stack<Stack::T>", shape=ellipse, style=filled, fillcolor=lightblue];
    T12 [label="convert_and_wrap::T", shape=ellipse, style=filled, fillcolor=lightblue];
    T13 [label="Wrapper<convert_and_wrap::U:MyFrom>", shape=ellipse, style=filled, fillcolor=lightblue];
    T14 [label="Pair::A", shape=ellipse, style=filled, fillcolor=lightblue];
    T15 [label="Pair::B", shape=ellipse, style=filled, fillcolor=lightblue];
    T16 [label="Pair<Pair::A, Pair::B>", shape=ellipse, style=filled, fillcolor=lightblue];
    T17 [label="Pair<Pair::B, Pair::A>", shape=ellipse, style=filled, fillcolor=lightblue];
    T18 [label="use_container::C:Container", shape=ellipse, style=filled, fillcolor=lightblue];
    T19 [label="<use_container::C:Container as generic_example::Container>::Item", shape=ellipse, style=filled, fillcolor=lightblue];
    T20 [label="usize", shape=ellipse, style=filled, fillcolor=lightgray];
    T21 [label="Counter", shape=ellipse, style=filled, fillcolor=lightblue];
  }

  // Function nodes (方框)
  subgraph cluster_functions {
    label="Functions";
    style=dashed;
    color=blue;
    F0 [label="Range::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F1 [label="wrap", shape=box, style=filled, fillcolor=palegreen];
    F2 [label="pair", shape=box, style=filled, fillcolor=palegreen];
    F3 [label="Wrapper<Wrapper::T>::new", shape=box, style=filled, fillcolor=palegreen];
    F4 [label="Wrapper<Wrapper::T>::get", shape=box, style=filled, fillcolor=palegreen];
    F5 [label="Wrapper<Wrapper::T>::get_mut", shape=box, style=filled, fillcolor=palegreen];
    F6 [label="Wrapper<Wrapper::T>::into_inner", shape=box, style=filled, fillcolor=palegreen];
    F7 [label="Wrapper<Wrapper::T>::map", shape=box, style=filled, fillcolor=palegreen];
    F8 [label="Stack<Stack::T>::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F9 [label="convert_and_wrap", shape=box, style=filled, fillcolor=palegreen];
    F10 [label="Pair<Pair::A, Pair::B>::new", shape=box, style=filled, fillcolor=palegreen];
    F11 [label="Pair<Pair::A, Pair::B>::first", shape=box, style=filled, fillcolor=palegreen];
    F12 [label="Pair<Pair::A, Pair::B>::second", shape=box, style=filled, fillcolor=palegreen];
    F13 [label="Pair<Pair::A, Pair::B>::swap", shape=box, style=filled, fillcolor=palegreen];
    F14 [label="use_container", shape=box, style=filled, fillcolor=palegreen];
    F15 [label="Counter::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F16 [label="Counter::with_value", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F17 [label="Counter::get", shape=box, style=filled, fillcolor=palegreen];
    F18 [label="Counter::increment", shape=box, style=filled, fillcolor=palegreen];
    F19 [label="Counter::reset", shape=box, style=filled, fillcolor=palegreen];
  }

  // Edges
  T0 -> F0 [label="copy", color=gray, style=solid];
  T0 -> F0 [label="copy", color=gray, style=solid];
  F0 -> T1 [label="→", color=black, style=solid];
  T2 -> F1 [label="move", color=black, style=solid];
  F1 -> T3 [label="→", color=black, style=solid];
  T4 -> F2 [label="move", color=black, style=solid];
  T5 -> F2 [label="move", color=black, style=solid];
  F2 -> T6 [label="→", color=black, style=solid];
  T7 -> F3 [label="move", color=black, style=solid];
  F3 -> T8 [label="→", color=black, style=solid];
  T8 -> F4 [label="&", color=blue, style=solid];
  F4 -> T7 [label="→&", color=blue, style=solid];
  T8 -> F5 [label="&mut", color=red, style=solid];
  F5 -> T7 [label="→&mut", color=red, style=solid];
  T8 -> F6 [label="move", color=black, style=solid];
  F6 -> T7 [label="→", color=black, style=solid];
  T8 -> F7 [label="move", color=black, style=solid];
  T9 -> F7 [label="move", color=black, style=solid];
  F7 -> T10 [label="→", color=black, style=solid];
  F8 -> T11 [label="→", color=black, style=solid];
  T12 -> F9 [label="move", color=black, style=solid];
  F9 -> T13 [label="→", color=black, style=solid];
  T14 -> F10 [label="move", color=black, style=solid];
  T15 -> F10 [label="move", color=black, style=solid];
  F10 -> T16 [label="→", color=black, style=solid];
  T16 -> F11 [label="&", color=blue, style=solid];
  F11 -> T14 [label="→&", color=blue, style=solid];
  T16 -> F12 [label="&", color=blue, style=solid];
  F12 -> T15 [label="→&", color=blue, style=solid];
  T16 -> F13 [label="move", color=black, style=solid];
  F13 -> T17 [label="→", color=black, style=solid];
  T18 -> F14 [label="&mut", color=red, style=solid];
  T19 -> F14 [label="move", color=black, style=solid];
  F14 -> T20 [label="→", color=black, style=solid];
  F15 -> T21 [label="→", color=black, style=solid];
  T0 -> F16 [label="copy", color=gray, style=solid];
  F16 -> T21 [label="→", color=black, style=solid];
  T21 -> F17 [label="&", color=blue, style=solid];
  F17 -> T0 [label="→", color=black, style=solid];
  T21 -> F18 [label="&mut", color=red, style=solid];
  T21 -> F19 [label="&mut", color=red, style=solid];
}
