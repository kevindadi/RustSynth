digraph ApiGraph {
  rankdir=LR;
  fontname="Helvetica";
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];

  // Type nodes (椭圆)
  subgraph cluster_types {
    label="Types";
    style=dashed;
    color=gray;
    T0 [label="Container", shape=ellipse, style=filled, fillcolor=lightblue];
    T1 [label="i32", shape=ellipse, style=filled, fillcolor=lightgray];
  }

  // Function nodes (方框)
  subgraph cluster_functions {
    label="Functions";
    style=dashed;
    color=blue;
    F0 [label="borrow_and_increment", shape=box, style=filled, fillcolor=palegreen];
    F1 [label="Container::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F2 [label="Container::get_ref", shape=box, style=filled, fillcolor=palegreen];
    F3 [label="Container::get_mut", shape=box, style=filled, fillcolor=palegreen];
    F4 [label="Container::increment", shape=box, style=filled, fillcolor=palegreen];
    F5 [label="Container::into_value", shape=box, style=filled, fillcolor=palegreen];
    F6 [label="borrow_and_read", shape=box, style=filled, fillcolor=palegreen];
  }

  // Edges
  T0 -> F0 [label="&mut[mut]", color=red, style=solid];
  T1 -> F1 [label="copy[own]", color=black, style=solid];
  F1 -> T0 [label="→[own]", color=black, style=solid];
  T0 -> F2 [label="&[shr]", color=blue, style=solid];
  F2 -> T1 [label="→&[shr]", color=blue, style=solid];
  T0 -> F3 [label="&mut[mut]", color=red, style=solid];
  F3 -> T1 [label="→&mut[mut]", color=red, style=solid];
  T0 -> F4 [label="&mut[mut]", color=red, style=solid];
  T0 -> F5 [label="move[own]", color=black, style=solid];
  F5 -> T1 [label="→[own]", color=black, style=solid];
  T0 -> F6 [label="&[shr]", color=blue, style=solid];
  F6 -> T1 [label="→&[shr]", color=blue, style=solid];
}
