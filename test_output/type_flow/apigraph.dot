digraph ApiGraph {
  rankdir=LR;
  fontname="Helvetica";
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];

  // Type nodes (椭圆)
  subgraph cluster_types {
    label="Types";
    style=dashed;
    color=gray;
    T0 [label="Sink", shape=ellipse, style=filled, fillcolor=lightblue];
    T1 [label="usize", shape=ellipse, style=filled, fillcolor=lightgray];
    T2 [label="ProcessedData", shape=ellipse, style=filled, fillcolor=lightblue];
    T3 [label="i32", shape=ellipse, style=filled, fillcolor=lightgray];
    T4 [label="MergedData", shape=ellipse, style=filled, fillcolor=lightblue];
    T5 [label="ParsedData", shape=ellipse, style=filled, fillcolor=lightblue];
    T6 [label="bool", shape=ellipse, style=filled, fillcolor=lightgray];
    T7 [label="RawData", shape=ellipse, style=filled, fillcolor=lightblue];
    T8 [label="Source", shape=ellipse, style=filled, fillcolor=lightblue];
  }

  // Function nodes (方框)
  subgraph cluster_functions {
    label="Functions";
    style=dashed;
    color=blue;
    F0 [label="Sink::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F1 [label="Sink::count", shape=box, style=filled, fillcolor=palegreen];
    F2 [label="ProcessedData::result", shape=box, style=filled, fillcolor=palegreen];
    F3 [label="ProcessedData::write_to", shape=box, style=filled, fillcolor=palegreen];
    F4 [label="ProcessedData::merge", shape=box, style=filled, fillcolor=palegreen];
    F5 [label="merge_sources", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F6 [label="ParsedData::process", shape=box, style=filled, fillcolor=palegreen];
    F7 [label="ParsedData::value", shape=box, style=filled, fillcolor=palegreen];
    F8 [label="ParsedData::is_valid", shape=box, style=filled, fillcolor=palegreen];
    F9 [label="MergedData::total", shape=box, style=filled, fillcolor=palegreen];
    F10 [label="RawData::parse", shape=box, style=filled, fillcolor=palegreen];
    F11 [label="RawData::get", shape=box, style=filled, fillcolor=palegreen];
    F12 [label="Source::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F13 [label="Source::read", shape=box, style=filled, fillcolor=palegreen];
    F14 [label="full_pipeline", shape=doubleoctagon, style=filled, fillcolor=palegreen];
  }

  // Edges
  F0 -> T0 [label="→", color=black, style=solid];
  T0 -> F1 [label="&", color=blue, style=solid];
  F1 -> T1 [label="→", color=black, style=solid];
  T2 -> F2 [label="&", color=blue, style=solid];
  F2 -> T3 [label="→", color=black, style=solid];
  T2 -> F3 [label="move", color=black, style=solid];
  T0 -> F3 [label="&mut", color=red, style=solid];
  T2 -> F4 [label="move", color=black, style=solid];
  T2 -> F4 [label="move", color=black, style=solid];
  F4 -> T4 [label="→", color=black, style=solid];
  T3 -> F5 [label="copy", color=gray, style=solid];
  T3 -> F5 [label="copy", color=gray, style=solid];
  F5 -> T4 [label="→", color=black, style=solid];
  T5 -> F6 [label="move", color=black, style=solid];
  F6 -> T2 [label="→", color=black, style=solid];
  T5 -> F7 [label="&", color=blue, style=solid];
  F7 -> T3 [label="→", color=black, style=solid];
  T5 -> F8 [label="&", color=blue, style=solid];
  F8 -> T6 [label="→", color=black, style=solid];
  T4 -> F9 [label="&", color=blue, style=solid];
  F9 -> T3 [label="→", color=black, style=solid];
  T7 -> F10 [label="move", color=black, style=solid];
  F10 -> T5 [label="→", color=black, style=solid];
  T7 -> F11 [label="&", color=blue, style=solid];
  F11 -> T3 [label="→", color=black, style=solid];
  T3 -> F12 [label="copy", color=gray, style=solid];
  F12 -> T8 [label="→", color=black, style=solid];
  T8 -> F13 [label="move", color=black, style=solid];
  F13 -> T7 [label="→", color=black, style=solid];
  T3 -> F14 [label="copy", color=gray, style=solid];
  F14 -> T2 [label="→", color=black, style=solid];
}
