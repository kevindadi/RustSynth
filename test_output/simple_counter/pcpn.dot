digraph PCPN {
  rankdir=LR;
  fontname="Helvetica";
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  // PCPN: One place per type (simplified)

  // ========== Places ==========
  p0 [label="i32\n[B=1]", shape=circle, style=filled, fillcolor=lightgray, peripheries=2];
  p1 [label="&i32\n[B=3]", shape=circle, style=filled, fillcolor=lightcyan, peripheries=1];
  p2 [label="&mut i32\n[B=3]", shape=circle, style=filled, fillcolor=mistyrose, peripheries=1];
  p3 [label="Counter\n[B=3]", shape=circle, style=filled, fillcolor=lightblue, peripheries=1];
  p4 [label="&Counter\n[B=3]", shape=circle, style=filled, fillcolor=lightcyan, peripheries=1];
  p5 [label="&mut Counter\n[B=3]", shape=circle, style=filled, fillcolor=mistyrose, peripheries=1];
  p6 [label="&&Counter\n[B=3]", shape=circle, style=filled, fillcolor=lightcyan, peripheries=1];

  // ========== Transitions ==========
  t0 [label="create_counter_with_value", shape=box, style=filled, fillcolor=palegreen];
  t1 [label="print_counter", shape=box, style=filled, fillcolor=palegreen];
  t2 [label="Counter::new", shape=box, style=filled, fillcolor=palegreen];
  t3 [label="Counter::increment", shape=box, style=filled, fillcolor=palegreen];
  t4 [label="Counter::get", shape=box, style=filled, fillcolor=palegreen];
  t5 [label="Counter::reset", shape=box, style=filled, fillcolor=palegreen];
  t6 [label="borrow_mut(Counter)", shape=box, style=filled, fillcolor=lavender];
  t7 [label="end_borrow_mut(Counter)", shape=box, style=filled, fillcolor=honeydew];
  t8 [label="borrow_shr(Counter)", shape=box, style=filled, fillcolor=lavender];
  t9 [label="end_borrow_shr(Counter)", shape=box, style=filled, fillcolor=honeydew];
  t10 [label="mut_to_shr(Counter)", shape=box, style=filled, fillcolor=wheat];
  t11 [label="drop(Counter)", shape=box, style=filled, fillcolor=gray90];
  t12 [label="dup_clone(Counter)", shape=box, style=filled, fillcolor=paleturquoise];
  t13 [label="deref(&&Counter)", shape=box, style=filled, fillcolor=wheat];
  t14 [label="const_i32", shape=diamond, style=filled, fillcolor=lightcyan];

  // ========== Arcs ==========
  p0 -> t0 [style=dashed, arrowhead=odot, color="black"];
  t0 -> p3 [style=solid, color="black"];
  p4 -> t1 [style=solid, arrowhead=normal, color="blue"];
  t2 -> p3 [style=solid, color="black"];
  p5 -> t3 [style=solid, arrowhead=normal, color="red"];
  p4 -> t4 [style=solid, arrowhead=normal, color="blue"];
  t4 -> p0 [style=solid, color="black"];
  p5 -> t5 [style=solid, arrowhead=normal, color="red"];
  p3 -> t6 [style=solid, arrowhead=normal, color="black"];
  t6 -> p5 [style=solid, color="red"];
  p5 -> t7 [style=solid, arrowhead=normal, color="red"];
  t7 -> p3 [style=solid, color="black"];
  p3 -> t8 [style=solid, arrowhead=normal, color="black"];
  t8 -> p4 [style=solid, color="blue"];
  p4 -> t9 [style=solid, arrowhead=normal, color="blue"];
  t9 -> p3 [style=solid, color="black"];
  p5 -> t10 [style=solid, arrowhead=normal, color="red"];
  t10 -> p4 [style=solid, color="blue"];
  p3 -> t11 [style=solid, arrowhead=normal, color="black"];
  p3 -> t12 [style=dashed, arrowhead=odot, color="black"];
  t12 -> p3 [style=solid, color="black"];
  p6 -> t13 [style=solid, arrowhead=normal, color="blue"];
  t13 -> p4 [style=solid, color="blue"];
  t14 -> p0 [style=solid, color="black"];
}
