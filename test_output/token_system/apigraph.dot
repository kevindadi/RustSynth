digraph ApiGraph {
  rankdir=LR;
  fontname="Helvetica";
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];

  // Type nodes (椭圆)
  subgraph cluster_types {
    label="Types";
    style=dashed;
    color=gray;
    T0 [label="Counter", shape=ellipse, style=filled, fillcolor=lightblue];
    T1 [label="i32", shape=ellipse, style=filled, fillcolor=lightgray];
  }

  // Function nodes (方框)
  subgraph cluster_functions {
    label="Functions";
    style=dashed;
    color=blue;
    F0 [label="print_counter", shape=box, style=filled, fillcolor=palegreen];
    F1 [label="create_counter_with_value", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F2 [label="Counter::new", shape=doubleoctagon, style=filled, fillcolor=palegreen];
    F3 [label="Counter::increment", shape=box, style=filled, fillcolor=palegreen];
    F4 [label="Counter::get", shape=box, style=filled, fillcolor=palegreen];
    F5 [label="Counter::reset", shape=box, style=filled, fillcolor=palegreen];
  }

  // Edges
  T0 -> F0 [label="&[shr]", color=blue, style=solid];
  T1 -> F1 [label="copy[own]", color=black, style=solid];
  F1 -> T0 [label="→[own]", color=black, style=solid];
  F2 -> T0 [label="→[own]", color=black, style=solid];
  T0 -> F3 [label="&mut[mut]", color=red, style=solid];
  T0 -> F4 [label="&[shr]", color=blue, style=solid];
  F4 -> T1 [label="→[own]", color=black, style=solid];
  T0 -> F5 [label="&mut[mut]", color=red, style=solid];
}
