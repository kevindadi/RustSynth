digraph ApiGraph {
  rankdir=LR;
  node [shape=box, style=rounded];

  n0 [label="print_counter\n(&Counter)", fillcolor=lightblue, style="rounded,filled", shape=box];
  n1 [label="create_counter_with_value\n(i32) → Counter", fillcolor=lightblue, style="rounded,filled", shape=doubleoctagon];
  n2 [label="new\n() → Counter", fillcolor=lightblue, style="rounded,filled", shape=doubleoctagon];
  n3 [label="increment\n(&mut Counter)", fillcolor=lightblue, style="rounded,filled", shape=box];
  n4 [label="get\n(&Counter) → i32", fillcolor=lightblue, style="rounded,filled", shape=box];
  n5 [label="reset\n(&mut Counter)", fillcolor=lightblue, style="rounded,filled", shape=box];

  n1 -> n0 [label="Counter (&)", color="black"];
  n1 -> n3 [label="Counter (&mut)", color="black"];
  n1 -> n4 [label="Counter (&)", color="black"];
  n1 -> n5 [label="Counter (&mut)", color="black"];
  n2 -> n0 [label="Counter (&)", color="black"];
  n2 -> n3 [label="Counter (&mut)", color="black"];
  n2 -> n4 [label="Counter (&)", color="black"];
  n2 -> n5 [label="Counter (&mut)", color="black"];
  n4 -> n1 [label="i32", color="gray"];
}
